<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- VIBRATE permission — required to trigger haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
        WAKE_LOCK — keeps the CPU running during a rest countdown so the
        countdown fires accurately even when the screen is off (Doze mode).
        Released as soon as the countdown ends or is cancelled.
    -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
        FOREGROUND_SERVICE — lets our TimerService keep running when the app
        is backgrounded (user switches to Netflix). Without this, Android
        would kill the service after a few minutes.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".GymTimerApp"
        android:allowBackup="true"
        android:label="GymTimer"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.GymTimer"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            TimerService declared as a foreground service.
            foregroundServiceType="specialUse" is required on Android 14+
            when no other category fits (timer tracking, not media playback).
        -->
        <service
            android:name=".service.TimerService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

    </application>

</manifest>
